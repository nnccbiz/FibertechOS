# =======================================================================
# FibertechOS environment variables
# Copy this file to .env.local and fill in the actual values.
# =======================================================================

# Public Supabase credentials (safe to expose to the browser - protected by RLS)
NEXT_PUBLIC_SUPABASE_URL=https://qiccyigkqunxhvqzncol.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste_anon_key_from_supabase_dashboard>

# Server-only: Supabase service_role key. Bypasses RLS. Keep it SECRET.
# Used by: /api/access-requests, /api/approve-request, /api/auth/log-attempt
SUPABASE_SERVICE_ROLE_KEY=<paste_service_role_key_from_supabase_dashboard>

# Site URL for email callbacks (password reset, invitation links)
NEXT_PUBLIC_SITE_URL=https://fibertech-os-git-dev-nnccbiz-4044s-projects.vercel.app
